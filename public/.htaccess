<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If file or folder exists, serve it normally
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, send everything to index.html (for React SPA)
  RewriteRule ^ index.html [L]
</IfModule>
